# =============================================================
# NeuroForge Enterprise SDLC Platform — Environment Template
# =============================================================
# Copy this file to .env for local development and fill in values.
# In production, inject these as environment variables directly
# (Docker -e flags, K8s secrets, cloud platform env config, etc.)
# DO NOT commit .env to version control.
# =============================================================


# ---------------------------
# Client / CORS
# ---------------------------
WEBAPP_ORIGIN=http://localhost:3000


# ---------------------------
# Database (PostgreSQL)
# ---------------------------
DB_URL=jdbc:postgresql://localhost:5432/neuroforge
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password


# ---------------------------
# JWT Security
# ---------------------------
# Use a strong, randomly generated secret (min 256-bit / 32 chars)
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_chars

# Token expiry durations (in seconds)
# JWT_ACCESS_TOKEN_EXPIRATION_SECONDS: 900 = 15 minutes
JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=900
# JWT_REFRESH_TOKEN_EXPIRATION_SECONDS: 604800 = 7 days
JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=604800

# Set to true in production (requires HTTPS)
JWT_COOKIE_SECURE=false
